# MONGODB_X509_CERT_BASE64=""

# Mapbox GL JS access token (public, browser-exposed via the NEXT_PUBLIC_ prefix).
# Get one at https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=
